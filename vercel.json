{
  "version": 2,
  "builds": [
    {
      "src": "beckend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/register",
      "destination": "/beckend/server.js"
    },
    {
      "source": "/login",
      "destination": "/beckend/server.js"
    },
    {
      "source": "/tasks(.*)",
      "destination": "/beckend/server.js"
    }
  ]
}